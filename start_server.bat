@echo off
title Anomaly Zone Mini-game Server
chcp 65001 > nul
color 0A

echo ======================================================================
echo  ☢️ СЕРВЕР МИНИ-ИГРЫ "АНОМАЛЬНАЯ ЗОНА" ЗАПУСКАЕТСЯ НА ПОРТУ 6112 ☢️
echo ======================================================================
echo.

:: Проверяем наличие установленного Node.js
where node >nul 2>nul
if %errorlevel% neq 0 (
    color 0C
    echo [ОШИБКА] Node.js не найден в вашей системе!
    echo Установите Node.js с официального сайта: https://nodejs.org/
    echo После установки перезапустите этот файл.
    echo.
    pause
    exit
)

echo [1/3] Проверка и установка зависимостей...
call npm install

echo.
echo [2/3] Сборка веб-приложения и серверного дистрибутива...
call npm run build

echo.
echo [3/3] Запуск сервера аномалий...
echo.
echo ----------------------------------------------------------------------
echo  👉 Ваш сервер успешно запущен и работает!
echo.
echo  🖥️ ДЛЯ КУРАТОРА (GM):
echo  Откройте браузер по адресу: http://localhost:6112/
echo.
echo  👥 ДЛЯ ОСТАЛЬНЫХ ИГРОКОВ:
echo  Они могут зайти по вашему локальному/публичному IP адресу:
echo  Пример: http://ВЫЧИСЛИТЕ_ВАШ_IP:6112/
echo ----------------------------------------------------------------------
echo.

set PORT=6112
set NODE_ENV=production
node dist/server.cjs

pause
